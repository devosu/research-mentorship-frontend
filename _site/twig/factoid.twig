<ul class="bux-factoid">
	{% for item in items %}	
		<li class="bux-factoid__item">
			<span class="bux-factoid__stat">
				{{ item.stat }}
			</span>
			<span class="bux-factoid__text">
				{{ item.text }}
			</span>
		</li>
	{% endfor %}
</ul>
