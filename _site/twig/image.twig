{% if caption %}
<figure>
{% endif %}

<img class="bux-image {{ class }}" src="{{ image_url }}" alt="{{ image_alt_text }}" />

{% if caption %}
<figcaption class="bux-image-caption">
	<div class="bux-image-caption__text">
		{{ caption_text }}
		{% if caption_attribution %}
		    ({{ caption_attribution }})
		{% endif %}
	</div>
</figcaption>
</figure>
{% endif %}
