<ul class="bux-link-list" role="list">
	{% for item in items %}	
	<li class="bux-link-list__item">
		<a
			class="bux-text-link"
			href="{{ item.url }}"
		>
			{{ item.link }}
		</a>
		{% if item.text %}
		<div class="bux-link-list__text">
			{{ item.text }}
		</div>
		{% endif %}
	</li>
	{% endfor %}
</ul>